# =============================================================================
# Algo Trading Agent — Environment Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control
# =============================================================================

# --- Zerodha KiteConnect ---
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=                  # Auto-populated daily by auth/kite_auth.py

# --- Zerodha Login (for Playwright auto-login) ---
ZERODHA_USER_ID=your_user_id
ZERODHA_PASSWORD=your_password
ZERODHA_TOTP_SECRET=your_totp_secret   # Base32 secret from authenticator app

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Trading Mode ---
PAPER_TRADING=true                  # MUST be true until strategy is verified live
TRADING_MODE=both                   # intraday | swing | both

# --- Capital ---
PAPER_TRADING_CAPITAL=1000000       # ₹10 lakh virtual capital for paper trading
LIVE_CAPITAL_LIMIT=100000           # ₹1 lakh max real capital (safety cap)

# --- Optional: Telegram Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
